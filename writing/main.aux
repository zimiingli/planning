\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The fixed-direction assumption fails on half of the environments---and the better the calibration, the worse the harm.} Prior entropy gating\nobreakspace  {}\citep  {seag2025,cats2025,corefine2026} assumes $\rho (\text  {entropy}, U){>}0$ (shaded). On Qwen3-4B, 3 of 6 envs violate this (HotpotQA, TWExpress, FEVER), so high-entropy triggering fires on the wrong states. In these environments, more accurate calibration translates to more precise harm-targeting: reversing the sign of the gate's learned weights drops SR by 23--37\,pp on strong-signal environments (Table\nobreakspace  {}\ref {tab:wrong-direction}).\relax }}{1}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:intro_reversal}{{1}{1}{\textbf {The fixed-direction assumption fails on half of the environments---and the better the calibration, the worse the harm.} Prior entropy gating~\cite {seag2025,cats2025,corefine2026} assumes $\rho (\text {entropy}, U){>}0$ (shaded). On Qwen3-4B, 3 of 6 envs violate this (HotpotQA, TWExpress, FEVER), so high-entropy triggering fires on the wrong states. In these environments, more accurate calibration translates to more precise harm-targeting: reversing the sign of the gate's learned weights drops SR by 23--37\,pp on strong-signal environments (Table~\ref {tab:wrong-direction}).\relax }{figure.caption.1}{}}
