\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {The DIAL pipeline.} \textbf  {(a) Explore}: collect signal-agnostic $(s, U)$ pairs via Bernoulli-$\varepsilon $ rollouts. \textbf  {(b) Reason}: build a candidate feature pool $\phi (s)$ from universal metrics plus optional LLM-proposed task-specific features. \textbf  {(c) Learn}: fit an $\ell _1$-regularized logistic gate, whose signed weights jointly perform feature selection and recover per-environment direction (Type\nobreakspace  {}D: $w_i{>}0$; Type\nobreakspace  {}I: $w_i{<}0$).\relax }}{6}{figure.caption.12}\protected@file@percent }
\newlabel{fig:method_overview}{{2}{6}{\textbf {The DIAL pipeline.} \textbf {(a) Explore}: collect signal-agnostic $(s, U)$ pairs via Bernoulli-$\varepsilon $ rollouts. \textbf {(b) Reason}: build a candidate feature pool $\phi (s)$ from universal metrics plus optional LLM-proposed task-specific features. \textbf {(c) Learn}: fit an $\ell _1$-regularized logistic gate, whose signed weights jointly perform feature selection and recover per-environment direction (Type~D: $w_i{>}0$; Type~I: $w_i{<}0$).\relax }{figure.caption.12}{}}
\newlabel{eq:dataset}{{3}{6}{Explore: Signal-Agnostic Data Collection}{equation.4.3}{}}
