\@writefile{lot}{\contentsline {table}{\numberline {18}{\ignorespaces Regularizer ablation on three environments ordered by signal strength. SR (\%); ``\#nz'' is the mean number of non-zero fitted weights across three seeds. The candidate pool $\phi _{\text  {cand}}$ contains 31 features ($5$\nobreakspace  {}universal $+\,3$\nobreakspace  {}derived $+\,20$\nobreakspace  {}hidden-state PCA $+\,3$\nobreakspace  {}auto-extracted); adding the LLM feature layer brings the pool to $\approx $36. $\ell _1$ is the only variant that achieves competitive SR \emph  {and} exact sparsity required by the signed-weight diagnostic.\relax }}{26}{table.caption.52}\protected@file@percent }
\newlabel{tab:regularizer-ablation}{{18}{26}{Regularizer ablation on three environments ordered by signal strength. SR (\%); ``\#nz'' is the mean number of non-zero fitted weights across three seeds. The candidate pool $\phi _{\text {cand}}$ contains 31 features ($5$~universal $+\,3$~derived $+\,20$~hidden-state PCA $+\,3$~auto-extracted); adding the LLM feature layer brings the pool to $\approx $36. $\ell _1$ is the only variant that achieves competitive SR \emph {and} exact sparsity required by the signed-weight diagnostic.\relax }{table.caption.52}{}}
