\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {The DIAL pipeline.} \textbf  {(a) Explore}: collect signal-agnostic $(s, U)$ pairs via Bernoulli-$\varepsilon $ rollouts. \textbf  {(b) Reason}: build a candidate feature pool $\phi (s)$ from universal metrics plus optional LLM-proposed task-specific features. \textbf  {(c) Learn}: fit an $\ell _1$-regularized logistic gate, whose signed weights jointly perform feature selection and recover per-environment direction (Type\nobreakspace  {}D: $w_i{>}0$; Type\nobreakspace  {}I: $w_i{<}0$).\relax }}{8}{figure.caption.14}\protected@file@percent }
\newlabel{fig:method_overview}{{3}{8}{\textbf {The DIAL pipeline.} \textbf {(a) Explore}: collect signal-agnostic $(s, U)$ pairs via Bernoulli-$\varepsilon $ rollouts. \textbf {(b) Reason}: build a candidate feature pool $\phi (s)$ from universal metrics plus optional LLM-proposed task-specific features. \textbf {(c) Learn}: fit an $\ell _1$-regularized logistic gate, whose signed weights jointly perform feature selection and recover per-environment direction (Type~D: $w_i{>}0$; Type~I: $w_i{<}0$).\relax }{figure.caption.14}{}}
\newlabel{eq:dataset}{{3}{8}{Explore: Signal-Agnostic Data Collection}{equation.4.3}{}}
